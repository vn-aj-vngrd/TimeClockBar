#!/bin/sh

message_file="$1"
first_line="$(sed -n '1p' "$message_file")"

case "$first_line" in
  feat:\ *|fix:\ *|docs:\ *|style:\ *|refactor:\ *|perf:\ *|test:\ *|build:\ *|ci:\ *|chore:\ *|revert:\ *)
    exit 0
    ;;
  Merge\ *|Revert\ *|fixup!\ *|squash!\ *)
    exit 0
    ;;
esac

echo "Commit message must start with a Conventional Commit prefix, like feat: or fix:" >&2
exit 1
